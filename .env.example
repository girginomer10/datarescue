# Runtime
DATARESCUE_ENVIRONMENT=development
DATARESCUE_REPLAY_MODE=true
DATARESCUE_EXECUTION_MODE=replay
DATARESCUE_DATABASE_PATH=.data/datarescue.sqlite3
DATARESCUE_ALLOWED_ASSETS=urn:li:dataset:(urn:li:dataPlatform:postgres,datarescue.raw.payments_raw,PROD)
# Optional; shown with their defaults. RUNTIME_DIR defaults to <tmp>/datarescue.
# DATARESCUE_RUNTIME_DIR=.data/runtime
DATARESCUE_DBT_PROJECT_DIR=demo/dbt
DATARESCUE_DBT_PROFILES_DIR=demo/dbt
DATARESCUE_DBT_TARGET=dev
DATARESCUE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATARESCUE_WEB_DIST_DIR=apps/web/dist

# PostgreSQL demo data plane
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DB=datarescue
POSTGRES_USER=datarescue
POSTGRES_PASSWORD=datarescue
# POSTGRES_DSN is informational for external psql tooling; the API itself reads
# only DATARESCUE_POSTGRES_DSN.
POSTGRES_DSN=postgresql://datarescue:datarescue@127.0.0.1:55432/datarescue
DATARESCUE_POSTGRES_DSN=postgresql://datarescue:datarescue@127.0.0.1:55432/datarescue
DBT_SCHEMA=analytics

# DataHub integration (optional in replay mode)
DATAHUB_GMS_URL=http://127.0.0.1:8080
DATAHUB_TOKEN=
DATARESCUE_DATAHUB_GMS_URL=http://127.0.0.1:8080
DATARESCUE_DATAHUB_TOKEN=
DATARESCUE_DATAHUB_MCP_URL=
DATARESCUE_DATAHUB_MCP_CONTEXT_TOOL=get_asset_context
DATARESCUE_DATAHUB_MCP_WRITE_TOOL=write_document
DATAHUB_KAFKA_BOOTSTRAP=127.0.0.1:9092
DATAHUB_SCHEMA_REGISTRY_URL=http://127.0.0.1:8081
DATAHUB_MCL_TOPIC=MetadataChangeLog_Versioned_v1

# Candidate generation (optional; deterministic replay remains available)
OPENAI_API_KEY=
DATARESCUE_OPENAI_API_KEY=
DATARESCUE_OPENAI_MODEL=gpt-5.6-terra
DATARESCUE_OPENAI_BASE_URL=https://api.openai.com/v1

# GitHub draft PR integration (optional; missing credentials produce NOT_RUN)
GITHUB_TOKEN=
DATARESCUE_GITHUB_WRITE_ENABLED=false
DATARESCUE_GITHUB_REPOSITORY=girginomer10/datarescue
DATARESCUE_GITHUB_BASE_BRANCH=main
DATARESCUE_GITHUB_REPO_ROOT=.
DATARESCUE_GITHUB_PATCH_PATH=demo/dbt/models/staging/stg_payments.sql

# Frontend (export these or copy them into apps/web/.env.local for Vite)
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_TIMEOUT_MS=3500
VITE_FORCE_REPLAY=false
VITE_BASE_PATH=/
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
